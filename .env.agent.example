# ---------------------------------------------------------------------------
# LogStream Agent — configuracao para POC
# ---------------------------------------------------------------------------
LOG_SERVER_ADDR=log-server:50051
LOG_SERVICE_ID=poc_mock_api
LOG_SERVICE_NAME=POC Mock API
LOG_VERSION=1.0.0
LOG_FILENAME_PREFIX=dados_basicos
LOG_VOLUME_PATH=/app/logs
LOG_DEFAULT_TTL_DAYS=7
LOG_MIN_LEVEL=INFO
LOG_BUFFER_SIZE=50000
LOG_BATCH_SIZE=100
LOG_FLUSH_MS=500
LOG_TLS_ENABLED=false
LOG_TLS_CERT_FILE=
LOG_METRICS_PORT=:9090
REDIS_URL=redis://redis-logstream:6379
REDIS_DB=1
REDIS_KEY_PREFIX=logagent
LOG_READ_EXISTING=true
AGENT_RESTART_WINDOW_MINUTES=5
AGENT_OFFSET_FLUSH_INTERVAL_MS=500
HEALTHMON_PORT=:9091
HEALTHMON_SERVICES=[{"id":"receita","name":"Receita Federal","base_url":"http://mock-dependencies:8001","health_path":"/receita/health","essential":false,"fallbacks":["bureau_1"],"error_threshold":0.50,"ping_interval_s":15},{"id":"bureau_1","name":"Bureau de Credito 1","base_url":"http://mock-dependencies:8001","health_path":"/bureau_1/health","essential":false,"fallbacks":["bureau_2"],"error_threshold":0.50,"ping_interval_s":15},{"id":"bureau_2","name":"Bureau de Credito 2","base_url":"http://mock-dependencies:8001","health_path":"/bureau_2/health","essential":false,"fallbacks":[],"error_threshold":0.50,"ping_interval_s":15},{"id":"cache","name":"Cache Distribuido","base_url":"http://mock-dependencies:8001","health_path":"/cache/health","essential":true,"fallbacks":[],"error_threshold":0.50,"ping_interval_s":15},{"id":"enrichment","name":"API Enriquecimento","base_url":"http://mock-dependencies:8001","health_path":"/enrichment/health","essential":false,"fallbacks":[],"error_threshold":0.50,"ping_interval_s":15}]
